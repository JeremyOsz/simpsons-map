generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  WIKI_PAGE
  REFERENCE_LINK
}

enum IngestionStatus {
  RUNNING
  COMPLETED
  FAILED
}

model Country {
  id              String    @id @default(cuid())
  iso2            String    @unique
  name            String
  mentionCount    Int       @default(0)
  isRegionEnabled Boolean   @default(false)
  mentions        Mention[]
  regions         Region[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Region {
  id           String    @id @default(cuid())
  countryIso2  String
  code         String
  name         String
  mentionCount Int       @default(0)
  country      Country   @relation(fields: [countryIso2], references: [iso2], onDelete: Cascade)
  mentions     Mention[]

  @@unique([countryIso2, code])
}

model Episode {
  id            String    @id @default(cuid())
  season        Int
  episodeNumber Int
  productionCode String?
  title         String
  airDate       DateTime?
  mentions      Mention[]

  @@unique([season, episodeNumber])
}

model Mention {
  id                    String      @id @default(cuid())
  countryIso2           String
  regionId              String?
  episodeId             String
  snippet               String
  normalizedSnippetHash String
  confidence            Float
  sourceUrl             String
  sourceType            SourceType
  isImplied             Boolean
  publishedAt           DateTime?
  createdAt             DateTime    @default(now())

  country Country @relation(fields: [countryIso2], references: [iso2], onDelete: Cascade)
  region  Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([countryIso2, episodeId, normalizedSnippetHash, sourceUrl])
}

model IngestionRun {
  id                String          @id @default(cuid())
  startedAt         DateTime        @default(now())
  completedAt       DateTime?
  status            IngestionStatus
  pagesScanned      Int             @default(0)
  mentionsExtracted Int             @default(0)
  mentionsPublished Int             @default(0)
  errorMessage      String?
}
